{
     "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "sway/mode", "custom/media"],
    "modules-center": ["sway/window"],
    "modules-right": [ "idle_inhibitor", "custom/pacman", "network", "wireplumber", "cpu", "memory", "temperature", "backlight", "battery", "battery#bat2", "clock", "custom/notification", "custom/lang", "tray"],
    
    // Modules configuration
    "sway/workspaces": {
         "disable-scroll": true,
    //     "all-outputs": true,
         "format": "{icon}",
         "format-icons": {
    //         "3": "",
             "1": "<span font='Arimo Nerd Font 13'>яЖ╝</span>", 
             "2": "<span font='Arimo Nerd Font 13'>яЙй</span>",
             "3": "<span font='Arimo Nerd Font 13'>яТЙ</span>",
             "4": "<span font='Arimo Nerd Font 15'>ґ░ИЪ</span>",
             "5": "<span font='Arimo Nerd Font 14'>юКЛ</span>",
             "6": "<span font='Arimo Nerd Font 13'>яАБ</span>",
             "7": "<span font='Arimo Nerd Font 13'>ґ░ЗД</span>",
             "8": "<span font='Arimo Nerd Font 13'>яБ╡</span>",
             "9": "<span font='Arimo Nerd Font 14'>яЖ╖</span>",
             "10": "<span font='Arimo Nerd Font 13'>яДЫ</span>",
    //         "5": "яБ╡",
    //         "urgent": "яБк",
    //         "focused": "яЖТ",
    //         "default": "яДС"
         }
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "яАг",
            "unlocked": "яВЬ"
        }
    },


    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) т╕и{songPosition}|{queueLength}т╕й {volume}% яАБ",
        "format-disconnected": "Disconnected яАБ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped яАБ",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "яГД "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">яБ┤</span> ",
            "on": "яБ┤ "
        },
        "repeat-icons": {
            "on": "яАЮ "
        },
        "single-icons": {
            "on": "яАЮ1 "
        },
        "state-icons": {
            "paused": "яБМ",
            "playing": "яБЛ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яСБ",
            "deactivated": "ґ░ИЙ"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "{:%d/%m/%Y}\n<tt><small>{calendar}</small></tt>",
        "format": "яД│ {:%a %d %b яАЧ %H:%M}",
        //"format": "{:яАЧ %H:%M}",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "яЛЫ {usage}%",
        "tooltip": false
    },
    //"custom/pacman": {
        //"format": "яЖЗ {}",
        //"interval": 7200,                     // every two hours
        //"exec": "checkupdates | wc -l",       // # of updates
        //"exec-if": "exit 0",                  // always run; consider advanced run conditions
        //"on-click": "alacritty -e sudo pacman -Syu ; pkill -SIGRTMIN+8 waybar", // update system
        //"signal": 8
    //},
    "memory": {
        "format": "яГЙ {}%"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{icon} {temperatureC}┬░",
        "format": "{icon} {temperatureC}┬░",
        "format-icons": ["яЛЛ", "яЛК", "яЛЙ", "яЛИ"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "format-icons": ["юМН", "ґ░Ци"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "ґ░Ги {capacity}%",
        "format-plugged": "яЗж {capacity}%",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-ethernet": "ґ░Ъе ",
        "on-click": "$HOME/.config/sway/scripts/nmcli-wofi",
        "format-wifi": "яЗл  {signalStrength}%",
        "format-disconnected": "тЪа Disconnected",
        "tooltip-format-wifi": "{essid}",
    },
    "pulseaudio": {
        "scroll-step": 2, // %, can be a float
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%яКФ {format_source}",
        "format-bluetooth-muted": "яСж яКФ {format_source}",
        "format-muted": "яСж {format_source}",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },
    "wireplumber": {
    "format": "{icon} {volume}%",
    "format-muted": "яСж",
    "on-click": "pavucontrol",
    "on-click-right": "helvum",
    "max-volume": 150,
    "scroll-step": 0.2,
    "format-icons": ["яАж", "яАз", "яАи"]
    },
    "custom/pipewire": {
        "tooltip": false,
        "max-length": 6,
        "signal": 8,
        "restart-interval": 0,
        "exec": "$HOME/.config/waybar/scripts/pipewire.sh"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "яЖ╝",
            "default": "ЁЯОЬ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },

"sway/language": {
	"format": "{short}",
    "on-click": "$HOME/.config/sway/scripts/wofi_language.sh",
},

  "custom/lang": {
    "exec": "swaymsg -t get_inputs | grep layout_name | grep -v En | awk 'END{if(NR == 0){print \"EN\"}else{print toupper(substr($2,2,2))}}'",
    "interval": 1,
    "on-click": "$HOME/.config/sway/scripts/wofi_language.sh",
    "format": "{}"
  },
    "custom/notification": {
      "tooltip": false,
      "format": "{icon}",
      "format-icons": {
        "notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
        "none": "яВв",
        "dnd-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
        "dnd-none": "яЗ╖",
        "inhibited-notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
        "inhibited-none": "яВв",
        "dnd-inhibited-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
        "dnd-inhibited-none": "яЗ╖"
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true
    },
}


